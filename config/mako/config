# Take a look at the mako manpage with the command:
#   man 5 mako
# To view all configuration options.

include=~/.config/mako/mako-colors

font=Cozette 11
format=<b>%a ⏵</b> %s\n%b
sort=-time
layer=overlay
anchor=top-center
width=410
height=110
margin=15,5,0,5
padding=10,5,10
border-size=2
icons=1
max-icon-size=64
default-timeout=5000
ignore-timeout=1

[app-name=vesktop summary~="(.*(^| )orz|ORZ|sto|STO|otl|OTL( |$).*)"]
invisible=1

[mode=dnd]
invisible=1
